{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Codex Relay Hub",
  "version": "0.1.0",
  "identifier": "com.local.claude-codex-relay-hub",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Codex Relay Hub",
        "width": 1180,
        "height": 780,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
